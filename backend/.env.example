# Server Configuration
PORT=3001

# Email Notification Settings
EMAIL_FROM=Uptime Monitor <your-email@gmail.com>
EMAIL_TO=admin@example.com,ops@example.com

# --- Choose ONE email provider below ---

# Option 1: Mailgun API (Recommended)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-domain.mailgun.org
# MAILGUN_EU=false

# Option 2: SMTP (e.g. Gmail, SendGrid, or any SMTP server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Admin password configuration.
# If ADMIN_PASSWORD is set, it is synced to the database on every startup —
# this is the recommended approach for deployments where the database may be
# reset (e.g. Railway, Render, Docker without a persistent volume).
# ADMIN_PASSWORD=your-secure-password
#
# If ADMIN_PASSWORD is not set, the password is established on first login
# via the /admin URL and the hash is stored in the database (app_settings table).
